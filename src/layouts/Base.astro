---
/**
 * Shared layout for the Allusion site (EN / NL / FR).
 * Renders <head>, the sticky nav, the footer and the broken-logo-hide script.
 * Page-specific content is provided via <slot />.
 */
interface Props {
  lang: "en" | "nl" | "fr";
  title: string;
  description: string;
  path: string; // canonical path for this page, e.g. "/", "/nl/", "/fr/"
}

const { lang, title, description, path } = Astro.props;

const nav = {
  en: { infra: "Infrastructure", ventures: "Ventures", hub: "Hub", news: "News", contact: "Contact" },
  nl: { infra: "Infrastructuur", ventures: "Ventures", hub: "Hub", news: "Nieuws", contact: "Contact" },
  fr: { infra: "Infrastructure", ventures: "Ventures", hub: "Hub", news: "Actualités", contact: "Contact" },
}[lang];

const home = { en: "/", nl: "/nl/", fr: "/fr/" };

const footerLead = {
  en: "© 2026 Allusion BV · Ghent, Belgium · ",
  nl: "© 2026 Allusion BV · Gent, België · ",
  fr: "© 2026 Allusion BV · Gand, Belgique · ",
}[lang];

const junoLabel = {
  en: "Now running on ICP via Juno",
  nl: "Draait nu op ICP via Juno",
  fr: "Tourne désormais sur ICP via Juno",
}[lang];

const canonical = `https://allusion.be${path}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href="https://allusion.be/" />
    <link rel="alternate" hreflang="nl" href="https://allusion.be/nl/" />
    <link rel="alternate" hreflang="fr" href="https://allusion.be/fr/" />
    <link rel="icon" href="/assets/allusion-logo.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://allusion.be/assets/facade.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,400&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/app.css" />
  </head>
  <body>
    <header>
      <div class="wrap">
        <nav>
          <a class="brand" href={home[lang]} aria-label="Allusion"><img class="brandlogo" src="/assets/allusion-bone.png" alt="Allusion" /></a>
          <input type="checkbox" id="navtoggle" class="navtoggle" aria-label="Open menu" />
          <label for="navtoggle" class="hamburger" aria-hidden="true"><span></span><span></span><span></span></label>
          <div class="links">
            <a href="#infra">{nav.infra}</a>
            <a href="#ventures">{nav.ventures}</a>
            <a href="#hub">{nav.hub}</a>
            <a href="#news">{nav.news}</a>
            <a href="#contact">{nav.contact}</a>
            <span class="lang">
              <a class={lang === "en" ? "on" : undefined} href="/">EN</a>
              <a class={lang === "nl" ? "on" : undefined} href="/nl/">NL</a>
              <a class={lang === "fr" ? "on" : undefined} href="/fr/">FR</a>
            </span>
          </div>
        </nav>
      </div>
    </header>

    <slot />

    <footer>
      <div class="wrap">
        <div class="row">
          <span
            >{footerLead}<a href="https://juno.build" target="_blank" rel="noopener">{junoLabel}</a></span
          >
          <span
            ><a href="https://allusion.ventures" target="_blank" rel="noopener">allusion.ventures</a>
            &nbsp;·&nbsp;
            <a href="https://www.linkedin.com/company/allusion-be/" target="_blank" rel="noopener">LinkedIn</a></span
          >
        </div>
      </div>
    </footer>

    <script is:inline>
      document.querySelectorAll(".logoimg").forEach(function (i) {
        i.addEventListener("error", function () {
          i.style.display = "none";
        });
      });
    </script>
  </body>
</html>
